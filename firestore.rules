rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Explicitly allow connection test collection
    match /test/{docId} {
      allow read: if true;
    }

    // Reusable, hardened security primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSameUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "773569038ahmed@gmail.com" ||
        request.auth.token.email == "ahmed@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validation helper for Properties
    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'price', 'location', 'image', 'phone', 'desc', 'date'])
        && data.title is string && data.title.size() <= 250
        && data.price is string && data.price.size() <= 100
        && data.location is string && data.location.size() <= 150
        && data.image is string && data.image.size() <= 2000
        && data.phone is string && data.phone.size() <= 40
        && data.desc is string && data.desc.size() <= 5000
        && data.date is string && data.date.size() <= 100
        && (!data.keys().contains('userId') || data.userId is string)
        && (!data.keys().contains('approved') || data.approved is bool)
        && (!data.keys().contains('images') || (data.images is list && data.images.size() <= 15));
    }

    // Validation helper for Cars
    function isValidCar(data) {
      return data.keys().hasAll(['brand', 'model', 'price', 'image', 'phone', 'desc', 'date'])
        && data.brand is string && data.brand.size() <= 100
        && data.model is string && data.model.size() <= 100
        && data.price is string && data.price.size() <= 100
        && data.image is string && data.image.size() <= 2000
        && data.phone is string && data.phone.size() <= 40
        && data.desc is string && data.desc.size() <= 5000
        && data.date is string && data.date.size() <= 100
        && (!data.keys().contains('userId') || data.userId is string)
        && (!data.keys().contains('approved') || data.approved is bool)
        && (!data.keys().contains('images') || (data.images is list && data.images.size() <= 15));
    }

    // Validation helper for Users
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt'])
        && data.uid is string && data.uid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 200
        && data.email is string && data.email.size() <= 200
        && (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 2000))
        && (!data.keys().contains('role') || (data.role is string && data.role.size() <= 50));
    }

    // Collection: Real estate properties
    match /properties/{propertyId} {
      allow read: if true;

      // Create checks authorization & validation
      allow create: if isSignedIn() && isValidId(propertyId) && isValidProperty(incoming()) && (
        incoming().userId == request.auth.uid
      );

      // Safe update controls
      allow update: if isValidId(propertyId) && isValidProperty(incoming()) && (
        isAdmin() || (
          isSignedIn() && 
          existing().userId == request.auth.uid &&
          incoming().userId == existing().userId &&
          incoming().approved == existing().approved
        )
      );

      // Delete controls
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Collection: Luxury vehicles
    match /cars/{carId} {
      allow read: if true;

      // Create checks authorization & validation
      allow create: if isSignedIn() && isValidId(carId) && isValidCar(incoming()) && (
        incoming().userId == request.auth.uid
      );

      // Safe update controls
      allow update: if isValidId(carId) && isValidCar(incoming()) && (
        isAdmin() || (
          isSignedIn() && 
          existing().userId == request.auth.uid &&
          incoming().userId == existing().userId &&
          incoming().approved == existing().approved
        )
      );

      // Delete controls
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // Collection: Users profiles
    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      
      allow create: if isSameUser(userId) && isValidUser(incoming()) && (
        !incoming().keys().contains('role') || 
        incoming().role == 'user' || 
        (incoming().role == 'admin' && (request.auth.token.email == "773569038ahmed@gmail.com" || request.auth.token.email == "ahmed@gmail.com"))
      );
      
      // Standard users cannot change their own roles (prevent self-promotion)
      allow update: if isSameUser(userId) && isValidUser(incoming()) && (
        incoming().role == existing().role ||
        (incoming().role == 'admin' && (request.auth.token.email == "773569038ahmed@gmail.com" || request.auth.token.email == "ahmed@gmail.com"))
      );
      
      allow delete: if isAdmin();
    }
  }
}
